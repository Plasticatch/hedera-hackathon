# ─── PlastiCatch Environment Variables ───────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env with real credentials to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Supabase (required) ─────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → your project → Settings → API
VITE_SUPABASE_PROJECT_ID=your-project-id
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...your-publishable-key
VITE_SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key
# Server-side alias (used by seed scripts and edge functions)
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# ─── Gemini AI ────────────────────────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...your-gemini-api-key

# ─── WalletConnect (used by HashConnect for HashPack pairing) ────────────────
# Get a project ID at: https://cloud.walletconnect.com  (free tier is fine)
# Leave blank to use HashPack direct pairing without WalletConnect relay.
VITE_WALLETCONNECT_PROJECT_ID=

# ─── Hedera Testnet ───────────────────────────────────────────────────────────
# Create a testnet account at: https://portal.hedera.com
VITE_HEDERA_NETWORK=testnet
VITE_HEDERA_OPERATOR_ID=0.0.XXXXX
VITE_HEDERA_OPERATOR_KEY=302e...your-private-key
# Server-side aliases (no VITE_ prefix for Node/Edge Functions)
HEDERA_OPERATOR_ID=0.0.XXXXX
HEDERA_OPERATOR_KEY=302e...your-private-key

# ─── HCS Topic IDs ───────────────────────────────────────────────────────────
# Created automatically by: node scripts/init-hedera.js
VITE_ATTESTATION_TOPIC_ID=0.0.XXXXX
VITE_DID_TOPIC_ID=0.0.XXXXX
VITE_LEADERBOARD_TOPIC_ID=0.0.XXXXX
VITE_DISPUTE_TOPIC_ID=0.0.XXXXX
VITE_EVENT_TOPIC_ID=0.0.XXXXX

# ─── HCS-10 Impact Agent Topics ──────────────────────────────────────────────
# Also created by init-hedera.js — must be set as Supabase secrets too:
#   supabase secrets set IMPACT_AGENT_INBOUND_TOPIC=0.0.XXXXX
#   supabase secrets set IMPACT_AGENT_RESPONSE_TOPIC=0.0.XXXXX
VITE_IMPACT_AGENT_INBOUND_TOPIC=0.0.XXXXX
VITE_IMPACT_AGENT_RESPONSE_TOPIC=0.0.XXXXX
# Server-side aliases (used by edge functions — no VITE_ prefix)
IMPACT_AGENT_INBOUND_TOPIC=0.0.XXXXX
IMPACT_AGENT_RESPONSE_TOPIC=0.0.XXXXX

# ─── Protocol Accounts ───────────────────────────────────────────────────────
# Treasury and payment pool accounts on Hedera Testnet
VITE_PROTOCOL_TREASURY_ACCOUNT=0.0.XXXXX
VITE_PAYMENT_POOL_ACCOUNT=0.0.XXXXX
VITE_PRC_VAULT_ACCOUNT=0.0.XXXXX

# ─── Mirror Node ─────────────────────────────────────────────────────────────
VITE_MIRROR_NODE_URL=https://testnet.mirrornode.hedera.com

# ─── Smart Contracts (Hedera EVM / Hardhat deploy) ───────────────────────────
# Run: npx hardhat run contracts/scripts/deploy.js --network hederaTestnet
# Addresses are printed at the end of deployment — copy them here.
# The setup script (npm run setup) can deploy and fill these automatically.
VITE_COLLECTOR_REGISTRY_CONTRACT=0x0000000000000000000000000000000000000000
VITE_STATION_REGISTRY_CONTRACT=0x0000000000000000000000000000000000000000
VITE_PRC_TOKEN_CONTRACT=0x0000000000000000000000000000000000000000
VITE_CORPORATE_VAULT_CONTRACT=0x0000000000000000000000000000000000000000
VITE_CLEANUP_EVENT_POOL_CONTRACT=0x0000000000000000000000000000000000000000
VITE_REPUTATION_ORACLE_CONTRACT=0x0000000000000000000000000000000000000000

# ─── Recovery Agent ──────────────────────────────────────────────────────────
RECOVERY_AGENT_ZONES=MEDITERRANEAN_NORTH,ARABIAN_GULF,PACIFIC_PHILIPPINES
AGENT_PROCESSING_INTERVAL=10000
WEEKLY_REPORT_ENABLED=false

# ─── Security (server-side only) ─────────────────────────────────────────────
JWT_SECRET=REPLACE_WITH_RANDOM_JWT_SECRET
ADMIN_API_KEY=REPLACE_WITH_RANDOM_ADMIN_KEY
